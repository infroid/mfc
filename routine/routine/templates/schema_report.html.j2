<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Schema report — {{ report.generated_at }}</title>
  <style>
    :root {
      --cream:        #F7F1E3;
      --cream-deep:   #EFE6CF;
      --cream-soft:   #FBF7EC;
      --paper:        #FFFCF3;
      --kraft:        #E8DCC0;

      --ink:          #1F1A14;
      --ink-soft:     #3A332A;
      --ink-muted:    #6B6253;
      --ink-faint:    #9A8F7C;
      --rule:         rgba(31, 26, 20, 0.14);
      --rule-strong:  rgba(31, 26, 20, 0.28);

      --orange:       #FF6D2E;
      --orange-deep:  #E2531A;
      --orange-soft:  rgba(255, 109, 46, 0.14);

      --matcha:       #7A9C5A;
      --matcha-deep:  #5E7E40;
      --matcha-soft:  rgba(122, 156, 90, 0.18);

      --berry:        #C84B5A;
      --butter:       #F4D67A;

      --sans:  ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      --serif: "Iowan Old Style", "Palatino Linotype", Palatino, "Book Antiqua", Georgia, "Times New Roman", serif;
      --mono:  ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background:
        radial-gradient(circle at 12% 8%, var(--orange-soft), transparent 38%),
        radial-gradient(circle at 92% 6%, var(--matcha-soft), transparent 42%),
        var(--cream);
      color: var(--ink-soft);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }

    .wrap {
      max-width: 1080px;
      margin: 0 auto;
      padding: 56px 32px 96px;
    }

    /* ---------- Header ---------- */
    .report-head {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 24px;
      padding-bottom: 28px;
      margin-bottom: 40px;
      border-bottom: 1px solid var(--rule);
    }
    .eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-muted);
      font-weight: 500;
      margin: 0 0 12px;
    }
    .eyebrow::before {
      content: "";
      display: inline-block;
      width: 22px;
      height: 1px;
      background: var(--orange);
      vertical-align: middle;
      margin-right: 10px;
      transform: translateY(-2px);
    }
    h1.report-title {
      font-family: var(--sans);
      font-weight: 500;
      font-size: clamp(34px, 4.4vw, 52px);
      line-height: 1.0;
      letter-spacing: -0.035em;
      color: var(--ink);
      margin: 0;
    }
    h1.report-title em {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      color: var(--orange);
    }
    .report-meta {
      text-align: right;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.05em;
      color: var(--ink-muted);
      line-height: 1.6;
    }
    .report-meta .stamp {
      display: inline-block;
      padding: 6px 12px;
      border: 1px solid var(--ink);
      border-radius: 999px;
      background: var(--paper);
      color: var(--ink);
      box-shadow: 3px 3px 0 var(--ink);
      margin-top: 6px;
    }

    .toc {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 48px;
    }
    .toc a {
      font-family: var(--mono);
      font-size: 12px;
      text-decoration: none;
      color: var(--ink);
      background: var(--paper);
      border: 1px solid var(--ink);
      border-radius: 999px;
      padding: 6px 14px;
      box-shadow: 2px 2px 0 var(--ink);
      transition: transform .12s ease, box-shadow .12s ease;
    }
    .toc a:hover {
      transform: translate(-1px, -1px);
      box-shadow: 3px 3px 0 var(--orange);
    }

    /* ---------- Table card ---------- */
    .table-card {
      position: relative;
      background: var(--paper);
      border: 1px solid var(--ink);
      border-radius: 20px;
      box-shadow: 6px 6px 0 var(--ink);
      padding: 32px 36px 36px;
      margin-bottom: 44px;
    }
    .table-card + .table-card { margin-top: 4px; }

    .table-head {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: start;
      padding-bottom: 20px;
      border-bottom: 1px dashed var(--rule-strong);
      margin-bottom: 24px;
    }
    .table-name {
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -0.01em;
      margin: 0;
      display: inline-flex;
      align-items: center;
      gap: 10px;
    }
    .table-name::before {
      content: "▸";
      color: var(--orange);
      font-size: 18px;
      transform: translateY(-1px);
    }
    .table-comment {
      font-family: var(--serif);
      font-style: italic;
      font-size: 18px;
      color: var(--ink-soft);
      margin: 8px 0 0;
      line-height: 1.4;
    }

    .row-count {
      text-align: right;
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--ink-muted);
      line-height: 1.2;
    }
    .row-count .num {
      display: block;
      font-size: 32px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -0.02em;
      margin-top: 4px;
      font-feature-settings: "tnum" 1;
    }

    /* ---------- Section labels ---------- */
    .section-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-muted);
      font-weight: 600;
      margin: 28px 0 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-label::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--rule);
    }

    /* ---------- Columns table ---------- */
    .cols {
      width: 100%;
      border-collapse: collapse;
      background: var(--cream-soft);
      border: 1px solid var(--rule-strong);
      border-radius: 12px;
      overflow: hidden;
      font-family: var(--mono);
      font-size: 12.5px;
    }
    .cols thead th {
      text-align: left;
      padding: 10px 14px;
      background: var(--cream-deep);
      color: var(--ink);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
      border-bottom: 1px solid var(--rule-strong);
    }
    .cols tbody td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--rule);
      color: var(--ink-soft);
      vertical-align: top;
    }
    .cols tbody tr:last-child td { border-bottom: none; }
    .cols tbody tr:hover td { background: var(--paper); }
    .cols td.col-name {
      color: var(--ink);
      font-weight: 600;
    }
    .cols td.col-type {
      color: var(--matcha-deep);
    }
    .cols td.col-comment {
      font-family: var(--serif);
      font-style: italic;
      font-size: 13.5px;
      color: var(--ink-soft);
    }
    .nullable-yes {
      display: inline-block;
      padding: 1px 8px;
      border-radius: 999px;
      background: var(--orange-soft);
      color: var(--orange-deep);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .nullable-no {
      display: inline-block;
      padding: 1px 8px;
      border-radius: 999px;
      background: var(--matcha-soft);
      color: var(--matcha-deep);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .muted { color: var(--ink-faint); }

    /* ---------- Pills / lists ---------- */
    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .pill {
      font-family: var(--mono);
      font-size: 12px;
      padding: 5px 12px;
      border-radius: 999px;
      border: 1px solid var(--ink);
      background: var(--paper);
      color: var(--ink);
      box-shadow: 2px 2px 0 var(--ink);
    }
    .pill.pk {
      background: var(--butter);
    }
    .pill.fk {
      background: var(--paper);
    }
    .pill.fk .arrow {
      color: var(--orange);
      margin: 0 6px;
    }
    .pill.fk .ref {
      color: var(--ink-muted);
    }

    .stack-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 8px;
    }
    .stack-list li {
      font-family: var(--mono);
      font-size: 12.5px;
      color: var(--ink-soft);
      padding: 10px 14px;
      background: var(--cream-soft);
      border: 1px solid var(--rule);
      border-left: 3px solid var(--matcha);
      border-radius: 8px;
    }
    .stack-list.policies li {
      border-left-color: var(--berry);
    }
    .stack-list.stats li {
      border-left-color: var(--orange);
    }
    .stack-list .col {
      color: var(--ink);
      font-weight: 600;
    }
    .stack-list .kind {
      display: inline-block;
      margin: 0 8px;
      padding: 1px 8px;
      border-radius: 999px;
      background: var(--cream-deep);
      color: var(--ink-muted);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .stack-list .detail {
      color: var(--ink-muted);
    }

    .empty {
      font-family: var(--serif);
      font-style: italic;
      font-size: 14px;
      color: var(--ink-faint);
      margin: 0;
    }

    footer.report-foot {
      margin-top: 56px;
      padding-top: 24px;
      border-top: 1px solid var(--rule);
      font-family: var(--mono);
      font-size: 11px;
      color: var(--ink-faint);
      letter-spacing: 0.06em;
      text-align: center;
    }
    footer.report-foot span { color: var(--orange); }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="report-head">
      <div>
        <p class="eyebrow">MyFoodCraving · Routine</p>
        <h1 class="report-title">Supabase <em>schema</em> report</h1>
      </div>
      <div class="report-meta">
        generated<br>
        <span class="stamp">{{ report.generated_at }}</span>
      </div>
    </header>

    {% if report.tables %}
    <nav class="toc" aria-label="Tables">
      {% for table in report.tables %}
        <a href="#tbl-{{ table.name }}">{{ table.name }}</a>
      {% endfor %}
    </nav>
    {% endif %}

    {% for table in report.tables %}
    <section class="table-card" id="tbl-{{ table.name }}">
      <div class="table-head">
        <div>
          <h2 class="table-name">{{ table.name }}</h2>
          {% if table.comment %}<p class="table-comment">{{ table.comment }}</p>{% endif %}
        </div>
        <div class="row-count">
          rows
          <span class="num">{{ table.row_count }}</span>
        </div>
      </div>

      <div class="section-label">Columns</div>
      <table class="cols">
        <thead>
          <tr>
            <th>name</th>
            <th>type</th>
            <th>nullable</th>
            <th>default</th>
            <th>comment</th>
          </tr>
        </thead>
        <tbody>
        {% for c in table.columns %}
          <tr>
            <td class="col-name">{{ c.name }}</td>
            <td class="col-type">{{ c.type }}</td>
            <td>
              {% if c.nullable %}
                <span class="nullable-yes">yes</span>
              {% else %}
                <span class="nullable-no">no</span>
              {% endif %}
            </td>
            <td>{% if c.default %}{{ c.default }}{% else %}<span class="muted">—</span>{% endif %}</td>
            <td class="col-comment">{% if c.comment %}{{ c.comment }}{% else %}<span class="muted">—</span>{% endif %}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>

      {% if table.primary_key %}
      <div class="section-label">Primary key</div>
      <ul class="pill-row">
        {% for pk in table.primary_key %}
          <li class="pill pk">{{ pk }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if table.foreign_keys %}
      <div class="section-label">Foreign keys</div>
      <ul class="pill-row">
        {% for fk in table.foreign_keys %}
          <li class="pill fk">
            {{ fk.column }}<span class="arrow">→</span><span class="ref">{{ fk.references_table }}.{{ fk.references_column }}</span>
          </li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if table.policies %}
      <div class="section-label">RLS policies</div>
      <ul class="stack-list policies">
        {% for p in table.policies %}
          <li>{{ p }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if table.stats %}
      <div class="section-label">Aggregate stats</div>
      <ul class="stack-list stats">
        {% for s in table.stats %}
          <li>
            <span class="col">{{ s.column }}</span>
            <span class="kind">{{ s.kind }}</span>
            <span class="detail">{{ s.detail }}</span>
          </li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>
    {% endfor %}

    <footer class="report-foot">
      <span>◆</span> end of report <span>◆</span>
    </footer>
  </div>
</body>
</html>
