# MyFoodCraving CLI configuration.
# Copy to `automation/.env` (gitignored) and fill in the values from Supabase Studio.
#
#   cp automation/.env.sample automation/.env
#   $EDITOR automation/.env

# ─── Database connection (psycopg) ─────────────────────────────────────────
# Studio → Project Settings → Database → Connection string.
#
# Use the **Session pooler** URI (port 5432). It works on IPv4 networks and
# supports DDL. Looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Avoid:
#   - Direct connection (`db.<ref>.supabase.co:5432`) — IPv6 only, fails on
#     most home/cafe networks with "nodename nor servname provided".
#   - Transaction pooler (port 6543) — drops session-level features that
#     some DDL needs.
SUPABASE_DB_URL=postgresql://postgres.fqjzhntqppbcwvqtjscb:YOUR-PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ─── REST + Auth (supabase-py) ─────────────────────────────────────────────
# Project URL — same value that lives in the <meta> tags on the public site.
SUPABASE_URL=https://fqjzhntqppbcwvqtjscb.supabase.co

# Service-role key. Bypasses RLS — keep secret. Used by recipe import + future
# admin commands. Get from Supabase Studio → Project Settings → API → service_role.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ─── Optional ──────────────────────────────────────────────────────────────
# Publishable key (safe to commit). Only relevant if a future command wants to
# act as an anon caller for testing.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
