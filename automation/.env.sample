# MyFoodCraving CLI configuration.
# Copy to `automation/.env` (gitignored) and fill in the values from Supabase Studio.
#
#   cp automation/.env.sample automation/.env
#   $EDITOR automation/.env

# ─── Database connection (psycopg) ─────────────────────────────────────────
# Get from Supabase Studio → Project Settings → Database → Connection string → URI.
# Use the **direct** connection (port 5432), not the pooler — DDL needs session-level
# features the pooler doesn't expose. Replace YOUR-PASSWORD with the password set
# at project creation.
SUPABASE_DB_URL=postgresql://postgres.YOUR-PASSWORD@YOUR-REGION.pooler.supabase.com:5432/postgres

# ─── REST + Auth (supabase-py) ─────────────────────────────────────────────
# Project URL — same value that lives in the <meta> tags on the public site.
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# Service-role key. Bypasses RLS — keep secret. Used by recipe import + future
# admin commands. Get from Supabase Studio → Project Settings → API → service_role.
SUPABASE_SECRET_KEY=sb_secret_YOUR_SECRET_KEY_HERE

# ─── Optional ──────────────────────────────────────────────────────────────
# Publishable key (safe to commit). Only relevant if a future command wants to
# act as an anon caller for testing.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY_HERE

# ─── Optional: USDA FoodData Central ───────────────────────────────────────
# Required only for `mfc fetch-ingredient-nutrition`. Free key from
# https://fdc.nal.usda.gov/api-key-signup.html (1,000 req/hr default).
FDC_API_KEY=DEMO_KEY

# ─── Optional: Anthropic (for nutrition AI fallback) ───────────────────────
# Required only when `mfc fetch-ingredient-nutrition --ai-fallback` is used.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
