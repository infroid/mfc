  "steps": [
    {
      "id": 1,
      "title": "Sweat aromatics",
      "detail": "Heat olive oil in a wide pot. Sweat onion and fennel 8 min until soft. Add garlic, chili flakes 1 min.",
      "duration": 540,
      "tip": "Fennel adds a sweet anise note — distinct from celery.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/brodetto-fish-stew/step-01-sweat.jpg",
        "caption": "sweat aromatics"
      }
    },
    {
      "id": 2,
      "title": "Wine, then tomato",
      "detail": "Pour in wine; reduce by half, 4 min. Add tomatoes and stock; simmer 15 min until thickened.",
      "duration": 1140,
      "tip": "Reducing the wine first concentrates its flavor.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/brodetto-fish-stew/step-02-wine.jpg",
        "caption": "wine, then tomato"
      }
    },
    {
      "id": 3,
      "title": "Slip in the fish",
      "detail": "Cube fish into 2-inch pieces. Salt. Slip into broth, cover, simmer 6 min until just cooked. Don't stir — shake the pot.",
      "duration": 360,
      "tip": "Hardest fish goes in first; soft varieties last.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/brodetto-fish-stew/step-03-fish.jpg",
        "caption": "slip in the fish"
      }
    },
    {
      "id": 4,
      "title": "Plate and parsley",
      "detail": "Ladle into bowls. Drizzle olive oil, scatter parsley. Serve with crusty bread.",
