  "steps": [
    {
      "id": 1,
      "title": "Toast and rehydrate",
      "detail": "Toast chilies in a dry pot 30 sec per side. Cover with hot water 15 min, then blend with the soaking liquid into a smooth paste.",
      "duration": 1080,
      "tip": "Use the soak liquid in the blend — that's where the chili water-soluble flavor lives.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chili-con-carne/step-01-toast.jpg",
        "caption": "toast and rehydrate"
      }
    },
    {
      "id": 2,
      "title": "Brown the beef",
      "detail": "In a heavy pot, brown beef in batches over high. Set aside. Sweat onion 5 min, garlic 1 min in the rendered fat.",
      "duration": 1200,
      "tip": "Crowding = steaming. Take batches seriously.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chili-con-carne/step-02-brown.jpg",
        "caption": "brown the beef"
      }
    },
    {
      "id": 3,
      "title": "Bloom and deglaze",
      "detail": "Stir in tomato paste, cumin, oregano; cook 2 min. Pour in beer and scrape the fond. Add chili paste and stock.",
      "duration": 240,
      "tip": "Deglazing is non-negotiable — those brown bits ARE the flavor.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chili-con-carne/step-03-deglaze.jpg",
        "caption": "bloom and deglaze"
      }
    },
    {
      "id": 4,
      "title": "Slow simmer",
      "detail": "Return beef. Cover, simmer 90 min until beef shreds with a fork. Last 20 min uncovered to thicken.",
      "duration": 5400,
      "tip": "Better the next day. Make ahead if you can.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chili-con-carne/step-04-simmer.jpg",
        "caption": "slow simmer"
      }
    }
  ],
