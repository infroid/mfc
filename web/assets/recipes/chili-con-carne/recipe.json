    },
    {
      "name": "Tomato paste",
      "amt": "2 tbsp",
      "group": "sauce"
    },
    {
      "name": "Mexican lager beer",
      "amt": "1 bottle",
      "group": "liquid"
    },
    {
      "name": "Beef stock",
      "amt": "3 cups",
      "group": "liquid"
