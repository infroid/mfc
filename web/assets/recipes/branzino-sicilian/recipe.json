  "steps": [
    {
      "id": 1,
      "title": "Stuff the cavities",
      "detail": "Pat fish dry, salt inside and out. Stuff cavities with sliced lemon, garlic, and thyme.",
      "duration": 240,
      "tip": "Cavity perfumes the meat from inside out — don't skip the stuffing.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/branzino-sicilian/step-01-stuff.jpg",
        "caption": "stuff the cavities"
      }
    },
    {
      "id": 2,
      "title": "Build the bed",
      "detail": "Scatter cherry tomatoes, olives, capers on a sheet pan. Drizzle olive oil. Lay fish on top. Drizzle more oil.",
      "duration": 180,
      "tip": "Tomatoes cook into a silky pan sauce by the end.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/branzino-sicilian/step-02-bed.jpg",
        "caption": "build the bed"
      }
    },
    {
      "id": 3,
      "title": "Roast hot",
      "detail": "Roast at 425°F for 18 min. Eyes turn opaque, skin crisps, fish flakes off the bone.",
      "duration": 1080,
      "tip": "Don't open the oven early; whole fish needs trapped heat.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/branzino-sicilian/step-03-roast.jpg",
        "caption": "roast hot"
      }
    },
    {
      "id": 4,
      "title": "Plate and squeeze",
      "detail": "Lift fish onto a platter; spoon tomato-olive juices over. Squeeze fresh lemon. Serve whole at the table.",
      "duration": 120,
      "tip": "Lift the top fillet, then the spine, then the bottom fillet — easier than it sounds.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/branzino-sicilian/step-04-plate.jpg",
        "caption": "plate and squeeze"
      }
    }
