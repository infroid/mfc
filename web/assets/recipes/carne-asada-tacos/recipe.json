  "ingredients": [
    {
      "name": "Skirt or flank steak",
      "amt": "1.5 lb",
      "group": "main"
    },
    {
      "name": "Lime juice",
      "amt": "1/3 cup",
      "group": "sauce"
    },
    {
      "name": "Orange juice",
      "amt": "1/2 cup",
      "group": "sauce"
    },
    {
      "name": "Garlic",
      "amt": "5 cloves",
      "group": "aromatics"
    },
    {
      "name": "Cilantro",
      "amt": "1/2 cup",
      "group": "aromatics"
    },
    {
      "name": "Chili powder",
      "amt": "1 tbsp",
      "group": "spice"
    },
    {
      "name": "Cumin",
      "amt": "1 tsp",
      "group": "spice"
    },
    {
      "name": "Olive oil",
      "amt": "1/4 cup",
      "group": "fat"
    },
    {
      "name": "Corn tortillas",
      "amt": "12, warmed",
      "group": "main"
    },
    {
      "name": "White onion (diced) and cilantro",
      "amt": "for serving",
      "group": "finish"
    }
