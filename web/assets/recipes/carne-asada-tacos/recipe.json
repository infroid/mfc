  "steps": [
    {
      "id": 1,
      "title": "Marinate the steak",
      "detail": "Whisk citrus, garlic, cilantro, spices, olive oil, salt. Submerge steak; refrigerate 30 min (up to 4 hours).",
      "duration": 1800,
      "tip": "Don't go past 4 hours — citrus turns the meat mealy.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/carne-asada-tacos/step-01-marinate.jpg",
        "caption": "marinate the steak"
      }
    },
    {
      "id": 2,
      "title": "Sear hard",
      "detail": "Get a cast iron blazing hot. Pat steak dry; sear 3 min per side for medium-rare.",
      "duration": 360,
      "tip": "Wet steak from marinade = steam, not crust. Pat. Dry. Down.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/carne-asada-tacos/step-02-sear.jpg",
        "caption": "sear hard"
      }
    },
    {
      "id": 3,
      "title": "Rest then dice",
      "detail": "Rest steak 5 min. Slice thin across the grain, then dice — taco-sized.",
      "duration": 300,
      "tip": "Dicing happens after slicing — get the grain right first.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/carne-asada-tacos/step-03-dice.jpg",
        "caption": "rest then dice"
      }
    },
    {
      "id": 4,
      "title": "Warm and assemble",
      "detail": "Char tortillas over a flame or in a dry skillet 30 sec per side. Pile meat on top with diced onion, cilantro, lime wedge.",
      "duration": 300,
      "tip": "Two tortillas per taco — one breaks, the other catches.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/carne-asada-tacos/step-04-assemble.jpg",
        "caption": "warm and assemble"
      }
    }
  ],
