  "steps": [
    {
      "id": 1,
      "title": "Whisk batter and crema",
      "detail": "Whisk flour, cornmeal, salt with cold beer until just combined. Separately, whisk sour cream, mayo, lime juice, salt.",
      "duration": 120,
      "tip": "Cornmeal in the batter = signature Baja crunch.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baja-fish-tacos/step-01-batter.jpg",
        "caption": "whisk batter and crema"
      }
    },
    {
      "id": 2,
      "title": "Fry the fish",
      "detail": "Heat 2 inches oil to 360°F. Cut fish into thumb-sized strips, dip in batter, fry 3 min until deep gold. Drain on rack.",
      "duration": 720,
      "tip": "Fish strips, not full fillets — taco-friendly portions.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baja-fish-tacos/step-02-fry.jpg",
        "caption": "fry the fish"
      }
    },
    {
      "id": 3,
      "title": "Char tortillas",
      "detail": "Char corn tortillas directly over a flame or in a dry pan 30 sec per side until soft and spotted.",
      "duration": 240,
      "tip": "Wrap charred tortillas in a clean towel — keeps them warm and supple.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baja-fish-tacos/step-03-char.jpg",
        "caption": "char tortillas"
      }
    },
    {
      "id": 4,
      "title": "Build with slaw",
      "detail": "Layer fish in tortillas, top with cabbage, drizzle crema, scatter cilantro. Squeeze lime over each.",
