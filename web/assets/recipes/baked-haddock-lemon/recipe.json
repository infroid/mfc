    },
    {
      "name": "Parsley",
      "amt": "2 tbsp chopped",
      "group": "finish"
    },
    {
      "name": "Dijon mustard",
      "amt": "1 tbsp",
      "group": "sauce"
    },
    {
      "name": "Salt and pepper",
      "amt": "to taste",
      "group": "spice"
    }
  ],
  "steps": [
    {
      "id": 1,
      "title": "Make the crumb",
      "detail": "Stir panko with melted butter, grated garlic, lemon zest, parsley, salt, pepper.",
      "duration": 120,
      "tip": "Crumb should clump when pressed — that means enough butter.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baked-haddock-lemon/step-01-crumb.jpg",
        "caption": "make the crumb"
      }
    },
    {
      "id": 2,
      "title": "Mustard and lemon",
      "detail": "Place haddock in a buttered baking dish. Brush with Dijon and squeeze lemon juice over.",
      "duration": 60,
      "tip": "Dijon helps the crumb cling without flour or egg.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baked-haddock-lemon/step-02-mustard.jpg",
        "caption": "mustard and lemon"
      }
    },
    {
      "id": 3,
      "title": "Crumb-top",
      "detail": "Press crumb onto each fillet, covering completely.",
      "duration": 60,
      "tip": "Use the back of a spoon to press — keeps it from falling off.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baked-haddock-lemon/step-03-top.jpg",
        "caption": "crumb-top"
      }
    },
    {
      "id": 4,
      "title": "Bake until gold",
      "detail": "Bake at 400°F for 14 min until crumb is golden and fish flakes. Squeeze fresh lemon over.",
      "duration": 840,
      "tip": "If crumb browns too fast, tent with foil for the last few minutes.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/baked-haddock-lemon/step-04-bake.jpg",
        "caption": "bake until gold"
      }
    }
  ],
