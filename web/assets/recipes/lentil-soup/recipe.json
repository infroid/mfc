  "steps": [
    {
      "id": 1,
      "title": "Soffritto",
      "detail": "Sweat onion, carrot, celery in olive oil over medium 8 minutes. Add garlic, cook 1 minute more.",
      "duration": 540,
      "tip": "Dice everything to lentil size — visual harmony matters.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/lentil-soup/step-01-soffritto.jpg",
        "caption": "soffritto"
      }
    },
    {
      "id": 2,
      "title": "Bloom the cumin",
      "detail": "Stir in cumin and cook 30 seconds until fragrant — toasting unlocks the oil-soluble flavors.",
      "duration": 30,
      "tip": "Fresh-ground cumin smells night-and-day better than pre-ground.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/lentil-soup/step-02-cumin.jpg",
        "caption": "bloom the cumin"
      }
    },
    {
      "id": 3,
      "title": "Simmer with stock",
      "detail": "Stir in lentils and stock. Bring to a boil, then simmer 25 minutes until lentils are tender but still hold shape.",
      "duration": 1500,
      "tip": "No salt yet — it slows lentil softening. Salt at the end.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/lentil-soup/step-03-simmer.jpg",
        "caption": "simmer with stock"
      }
    },
    {
      "id": 4,
      "title": "Brighten and serve",
      "detail": "Salt to taste. Squeeze in lemon and stir in chopped parsley off heat.",
      "duration": 60,
      "tip": "Lemon wakes the soup up — without it the soup tastes flat.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/lentil-soup/step-04-brighten.jpg",
        "caption": "brighten and serve"
      }
    }
