  "steps": [
    {
      "id": 1,
      "title": "Build the sauce",
      "detail": "Heat olive oil in a wide pan. Sweat onion 6 min. Add garlic 1 min. Pour in tomatoes; simmer 8 min until thickened.",
      "duration": 900,
      "tip": "Cook off some of the canned tomato sharpness before adding fish.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/tilapia-veracruz/step-01-sauce.jpg",
        "caption": "build the sauce"
      }
    },
    {
      "id": 2,
      "title": "Olives, capers, jalapeño",
      "detail": "Stir in olives, capers, jalapeños, bay leaf. Simmer 3 min.",
      "duration": 180,
      "tip": "Saltiness builds: taste before adding any extra salt.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/tilapia-veracruz/step-02-olives.jpg",
        "caption": "olives, capers, jalapeño"
      }
    },
    {
      "id": 3,
      "title": "Nestle the fish",
      "detail": "Salt tilapia. Slip fillets into the sauce. Spoon sauce over the tops. Cover, simmer 6–8 min until fish flakes.",
      "duration": 480,
      "tip": "Don't flip — the fish breaks. Just spoon sauce over.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/tilapia-veracruz/step-03-nestle.jpg",
        "caption": "nestle the fish"
      }
    },
    {
      "id": 4,
      "title": "Cilantro and serve",
      "detail": "Discard bay leaf. Scatter cilantro over the top. Serve with rice or warm tortillas.",
      "duration": 60,
      "tip": "A dose of lime over each portion sharpens the whole dish.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/tilapia-veracruz/step-04-serve.jpg",
        "caption": "cilantro and serve"
      }
    }
  ],
