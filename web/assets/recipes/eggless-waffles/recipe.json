  "ingredients": [
    {
      "name": "All-purpose flour",
      "amt": "1.5 cups",
      "group": "main"
    },
    {
      "name": "Cornstarch",
      "amt": "1/2 cup",
      "group": "main"
    },
    {
      "name": "Sparkling water (cold)",
      "amt": "1.25 cups",
      "group": "liquid"
    },
    {
      "name": "Whole milk",
      "amt": "1/2 cup",
      "group": "liquid"
    },
    {
      "name": "Melted butter",
      "amt": "1/2 cup",
      "group": "fat"
    },
    {
      "name": "Sugar",
      "amt": "2 tbsp",
      "group": "sweetener"
    },
    {
      "name": "Baking powder",
      "amt": "2 tsp",
      "group": "leavening"
    },
    {
      "name": "Salt",
      "amt": "1/2 tsp",
      "group": "spice"
    },
    {
      "name": "Vanilla",
      "amt": "1 tsp",
      "group": "finish"
    }
  ],
  "steps": [
    {
      "id": 1,
      "title": "Whisk dry",
      "detail": "Whisk flour, cornstarch, sugar, baking powder, salt in a bowl.",
      "duration": 60,
      "tip": "Sift if you have time — cornstarch loves to clump.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/eggless-waffles/step-01-dry.jpg",
        "caption": "whisk dry"
      }
    },
    {
      "id": 2,
      "title": "Whisk wet, last second",
      "detail": "In another bowl, whisk milk, melted butter, vanilla. Just before cooking, add cold sparkling water.",
      "duration": 60,
      "tip": "Bubbles deflate — the longer the batter sits, the less crisp the waffle.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/eggless-waffles/step-02-wet.jpg",
        "caption": "whisk wet, last second"
      }
    },
    {
      "id": 3,
      "title": "Fold and rest 1 minute",
      "detail": "Fold wet into dry until just combined. Rest 1 minute — barely longer.",
      "duration": 60,
      "tip": "Lumps = good. Smooth = waffle pancake.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/eggless-waffles/step-03-fold.jpg",
        "caption": "fold and rest 1 minute"
      }
    },
    {
      "id": 4,
      "title": "Cook till deep gold",
      "detail": "Pour into a hot, oiled waffle iron. Cook until the edges go deep gold and steam slows — usually 4–5 minutes per Belgian waffle.",
      "duration": 300,
      "tip": "Pull pale = chewy. Pull dark = crisp. Pick your camp.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/eggless-waffles/step-04-cook.jpg",
        "caption": "cook till deep gold"
      }
    }
  ],
