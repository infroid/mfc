  "ingredients": [
    {
      "name": "Yellow cornmeal",
      "amt": "1.5 cups",
      "group": "main"
    },
    {
      "name": "All-purpose flour",
      "amt": "1/2 cup",
      "group": "main"
    },
    {
      "name": "Buttermilk",
      "amt": "1.25 cups",
      "group": "liquid"
    },
    {
      "name": "Eggs",
      "amt": "2",
      "group": "main"
    },
    {
      "name": "Melted butter",
      "amt": "1/3 cup",
      "group": "fat"
    },
    {
      "name": "Sugar",
      "amt": "2 tbsp (optional)",
      "group": "sweetener"
    },
    {
      "name": "Baking powder",
      "amt": "1.5 tsp",
      "group": "leavening"
    },
    {
      "name": "Baking soda",
      "amt": "1/2 tsp",
      "group": "leavening"
    },
    {
      "name": "Salt",
      "amt": "1 tsp",
      "group": "spice"
    }
  ],
  "steps": [
    {
      "id": 1,
      "title": "Preheat cast iron",
      "detail": "Place a 10-inch cast iron skillet in a 425°F oven. Heat 10 minutes — the pan must be searing hot.",
      "duration": 600,
      "tip": "Cold pan = sad bottom. Hot pan = crackly crust.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/classic-cornbread/step-01-preheat.jpg",
        "caption": "preheat cast iron"
      }
    },
    {
      "id": 2,
      "title": "Whisk dry, then wet",
      "detail": "Whisk cornmeal, flour, baking powder, soda, salt, sugar (if using). In a separate bowl, whisk buttermilk, eggs, melted butter (cooled).",
      "duration": 120,
      "tip": "Hot melted butter scrambles the eggs — let it cool.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/classic-cornbread/step-02-mix.jpg",
        "caption": "whisk dry, then wet"
      }
    },
    {
      "id": 3,
      "title": "Combine, leave lumpy",
      "detail": "Pour wet into dry; fold gently. Stop while lumps remain.",
      "duration": 60,
      "tip": "Smooth = chewy. Lumpy = tender.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/classic-cornbread/step-03-combine.jpg",
        "caption": "combine, leave lumpy"
      }
    },
    {
      "id": 4,
      "title": "Pour into screaming pan",
      "detail": "Pull skillet from oven. Add 1 tbsp butter, swirl to coat. Pour batter — should sizzle. Bake 22 min until top is golden and a toothpick comes clean.",
      "duration": 1320,
      "tip": "The sizzle when the batter hits the pan is the sound of victory.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/classic-cornbread/step-04-bake.jpg",
        "caption": "pour into screaming pan"
      }
    }
  ],
