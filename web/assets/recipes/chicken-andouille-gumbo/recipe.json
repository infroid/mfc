  "ingredients": [
    {
      "name": "Chicken thighs (cubed)",
      "amt": "1.5 lb",
      "group": "main"
    },
    {
      "name": "Andouille sausage (sliced)",
      "amt": "12 oz",
      "group": "main"
    },
    {
      "name": "All-purpose flour",
      "amt": "1/2 cup",
      "group": "thickener"
    },
    {
      "name": "Vegetable oil",
      "amt": "1/2 cup",
      "group": "fat"
    },
    {
      "name": "Onion (diced)",
      "amt": "1 large",
      "group": "aromatics"
    },
    {
      "name": "Celery (diced)",
      "amt": "3 stalks",
      "group": "aromatics"
    },
    {
      "name": "Bell pepper",
      "amt": "1, diced",
      "group": "aromatics"
    },
    {
      "name": "Garlic",
      "amt": "6 cloves",
      "group": "aromatics"
    },
    {
      "name": "Chicken stock",
      "amt": "6 cups",
      "group": "liquid"
    },
    {
      "name": "Bay leaves",
      "amt": "2",
      "group": "aromatics"
    },
    {
      "name": "Filé powder",
      "amt": "1 tsp (off heat)",
      "group": "spice"
    }
  ],
  "steps": [
    {
      "id": 1,
      "title": "Build the dark roux",
      "detail": "Whisk flour and oil in a heavy pot over medium-low. Stir constantly 25–35 min until the color of milk chocolate. Don't walk away.",
      "duration": 1800,
      "tip": "Burnt roux is bitter and there's no fixing it. Patience.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chicken-andouille-gumbo/step-01-roux.jpg",
        "caption": "build the dark roux"
      }
    },
    {
      "id": 2,
      "title": "Add the trinity",
      "detail": "Toss in onion, celery, bell pepper. Stir 5 min — they'll stop the roux from getting darker. Add garlic 1 min.",
      "duration": 360,
      "tip": "Cold vegetables actually halt roux color, which is the trick.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chicken-andouille-gumbo/step-02-trinity.jpg",
        "caption": "add the trinity"
      }
    },
    {
      "id": 3,
      "title": "Build the gumbo",
      "detail": "Slowly whisk in stock. Add bay leaves, andouille, chicken, salt. Bring to a simmer.",
      "duration": 600,
      "tip": "Add stock in stages and whisk hard — lumps form fast.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chicken-andouille-gumbo/step-03-build.jpg",
        "caption": "build the gumbo"
      }
    },
    {
      "id": 4,
      "title": "Slow and finish",
      "detail": "Simmer 50 min, skimming any surface fat. Off heat, sprinkle filé powder; stir. Serve over rice.",
      "duration": 3000,
      "tip": "Filé only off heat — boiling makes it stringy.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/chicken-andouille-gumbo/step-04-finish.jpg",
        "caption": "slow and finish"
      }
    }
  ],
