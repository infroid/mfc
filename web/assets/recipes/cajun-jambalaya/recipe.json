  "ingredients": [
    {
      "name": "Andouille sausage (sliced)",
      "amt": "12 oz",
      "group": "main"
    },
    {
      "name": "Chicken thighs (cubed)",
      "amt": "1 lb",
      "group": "main"
    },
    {
      "name": "Long-grain white rice",
      "amt": "2 cups",
      "group": "main"
    },
    {
      "name": "Onion (diced)",
      "amt": "1 large",
      "group": "aromatics"
    },
    {
      "name": "Celery (diced)",
      "amt": "3 stalks",
      "group": "aromatics"
    },
    {
      "name": "Green bell pepper",
      "amt": "1, diced",
      "group": "aromatics"
    },
    {
      "name": "Garlic",
      "amt": "5 cloves",
      "group": "aromatics"
    },
    {
      "name": "Diced tomatoes",
      "amt": "1 (15oz) can",
      "group": "sauce"
    },
    {
      "name": "Cajun seasoning",
      "amt": "2 tbsp",
      "group": "spice"
    },
    {
      "name": "Chicken stock",
      "amt": "3.5 cups",
      "group": "liquid"
    }
  ],
  "steps": [
    {
      "id": 1,
      "title": "Brown the meat",
      "detail": "Brown andouille in a Dutch oven 4 min. Set aside. Brown chicken in the rendered fat 6 min. Set aside.",
      "duration": 600,
      "tip": "Andouille fat is your seasoning — leave it in the pot.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/cajun-jambalaya/step-01-meat.jpg",
        "caption": "brown the meat"
      }
    },
    {
      "id": 2,
      "title": "Holy trinity",
      "detail": "Add onion, celery, bell pepper to the pot. Cook 8 min until softened. Add garlic and cajun seasoning, cook 1 min.",
      "duration": 540,
      "tip": "Cajun seasoning is salt-heavy — don't add more salt yet.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/cajun-jambalaya/step-02-trinity.jpg",
        "caption": "holy trinity"
      }
    },
    {
      "id": 3,
      "title": "Tomato, rice, stock",
      "detail": "Stir in tomatoes; cook 3 min. Add rice; toast 2 min. Pour in stock; return meat. Bring to a boil.",
      "duration": 360,
      "tip": "Toasting the rice keeps each grain separate.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/cajun-jambalaya/step-03-rice.jpg",
        "caption": "tomato, rice, stock"
      }
    },
    {
      "id": 4,
      "title": "Cover and cook",
      "detail": "Cover, drop heat to low, cook 20 min undisturbed. Rest 10 min covered off heat. Fluff with a fork.",
      "duration": 1800,
      "tip": "Don't peek — rice steaming requires trapped heat.",
      "media": {
        "src": "https://fqjzhntqppbcwvqtjscb.supabase.co/storage/v1/object/public/recipe-images/cajun-jambalaya/step-04-cover.jpg",
        "caption": "cover and cook"
      }
    }
  ],
