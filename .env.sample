# MyFoodCraving CLI configuration.
# Copy to `.env` (gitignored) and fill in the values from Supabase Studio.

# ─── Database connection (psycopg) ─────────────────────────────────────────
# Get from Supabase Studio → Project Settings → Database → Connection string → URI.
# Use the **direct** connection (port 5432), not the pooler — DDL needs session-level
# features the pooler doesn't expose. Replace YOUR-PASSWORD with the password set
# at project creation.
SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.fqjzhntqppbcwvqtjscb.supabase.co:5432/postgres

# ─── REST + Auth (supabase-py) ─────────────────────────────────────────────
# Project URL — same value that lives in the <meta> tags on the public site.
SUPABASE_URL=https://fqjzhntqppbcwvqtjscb.supabase.co

# Service-role key. Bypasses RLS — keep secret. Used by recipe import + future
# admin commands. Get from Supabase Studio → Project Settings → API → service_role.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ─── Optional ──────────────────────────────────────────────────────────────
# Publishable key (safe to commit). Only relevant if a future command wants to
# act as an anon caller for testing.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
